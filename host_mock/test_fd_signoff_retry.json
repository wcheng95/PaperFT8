{
  "config": {
    "MY_CALLSIGN": "AG6AQ",
    "MY_GRID": "CM97",
    "DX_CALLSIGN": "N6HAN",
    "DX_GRID": "CM87",
    "TX_ON_EVEN": true,
    "CQ_TYPE": "FD",
    "FREE_TEXT": "1B SCV"
  },
  "periods": [
    {
      "comment": "Period 0 (even): idle",
      "messages": []
    },
    {
      "comment": "Period 1 (odd): DX sends CQ FD — we touch to reply",
      "messages": [
        {
          "call_to": "CQ FD",
          "call_from": "${DX_CALLSIGN}",
          "locator": "${DX_GRID}",
          "snr": -8,
          "slot": 1,
          "freq_hz": 1200
        }
      ],
      "touch_event": {
        "time_offset": 14.0,
        "message_index": 0
      }
    },
    {
      "comment": "Period 2 (even): we send TX2 (exchange) to DX",
      "messages": []
    },
    {
      "comment": "Period 3 (odd): DX sends R + FD exchange (TX3)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "R 1A SCV",
          "snr": -6,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 4 (even): we send RR73 (TX4) — QSO logged here",
      "messages": []
    },
    {
      "comment": "Period 5 (odd): DX sends RR73 back (they didn't get our RR73, or just confirming)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "RR73",
          "snr": 0,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 6 (even): we should be IDLE (ROGERS received TX4 → IDLE), no double log",
      "messages": []
    },
    {
      "comment": "Period 7 (odd): DX sends RR73 yet again (late)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "RR73",
          "snr": 0,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 8 (even): verify no TX, no extra logging",
      "messages": []
    }
  ]
}
