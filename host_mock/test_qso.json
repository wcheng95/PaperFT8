{
  "config": {
    "MY_CALLSIGN": "AG6AQ",
    "MY_GRID": "CM97",
    "DX_CALLSIGN": "N6HAN",
    "DX_GRID": "CM87",
    "TX_ON_EVEN": true
  },
  "periods": [
    {
      "comment": "Period 0: idle",
      "messages": []
    },
    {
      "comment": "Period 1 (odd): DX calls CQ — we touch to reply",
      "messages": [
        {
          "call_to": "CQ",
          "call_from": "${DX_CALLSIGN}",
          "locator": "${DX_GRID}",
          "snr": -5,
          "slot": 1,
          "freq_hz": 1200
        }
      ],
      "touch_event": {
        "time_offset": 14.0,
        "message_index": 0
      }
    },
    {
      "comment": "Period 2 (even): we send TX1 (grid) to DX",
      "messages": []
    },
    {
      "comment": "Period 3 (odd): DX sends TX2 (report)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "-12",
          "snr": -12,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 4 (even): we send TX3 (R+report)",
      "messages": []
    },
    {
      "comment": "Period 5 (odd): DX sends TX4 (RR73)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "RR73",
          "snr": 0,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 6 (even): we send TX5 (73), QSO complete",
      "messages": []
    }
  ]
}
