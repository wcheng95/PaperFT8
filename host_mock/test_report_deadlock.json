{
  "config": {
    "MY_CALLSIGN": "AG6AQ",
    "MY_GRID": "CM97",
    "DX_CALLSIGN": "N6HAN",
    "DX_GRID": "CM87",
    "TX_ON_EVEN": true
  },
  "periods": [
    {
      "comment": "Period 0 (even): beacon starts — we will CQ on even slots",
      "messages": [],
      "beacon_change": {
        "time_offset": 1.0,
        "beacon_on": 1
      }
    },
    {
      "comment": "Period 1 (odd): nothing — our CQ was sent in period 0",
      "messages": []
    },
    {
      "comment": "Period 2 (even): no RX yet, beacon sends another CQ",
      "messages": []
    },
    {
      "comment": "Period 3 (odd): DX sends TX1 (grid) in response to our CQ",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "${DX_GRID}",
          "snr": -10,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 4 (even): we send TX2 (report).  Autoseq should be in REPORT.",
      "messages": []
    },
    {
      "comment": "Period 5 (odd): DX sends TX2 (report WITHOUT R prefix) — BUG trigger",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "-07",
          "snr": -7,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 6 (even): we send TX3 (R+report). FIX: should be ROGER_REPORT.",
      "messages": []
    },
    {
      "comment": "Period 7 (odd): DX sends TX4 (RR73)",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "RR73",
          "snr": 0,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 8 (even): we send TX5 (73), QSO complete",
      "messages": []
    }
  ]
}
